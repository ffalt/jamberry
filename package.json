{
  "name": "jamberry",
  "version": "0.6.14",
  "author": "ffalt",
  "license": "MIT",
  "description": "a html5 jamserve web player",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:prod": "ng serve --aot --configuration production",
    "build": "ng build",
    "build:AOT": "ng build --aot",
    "check": "qlty check --all",
    "test": "ng test --watch false",
    "test:watch": "ng test --watch true",
    "test:coverage": "ng test --watch false --coverage",
    "lint": "ng lint && eslint .",
    "lint:fix": "ng lint --fix && eslint . --fix",
    "lint:scss": "stylelint \"**/*.scss\"",
    "lint:css": "stylelint \"**/*.css\"",
    "clean": "rimraf dist",
    "i18n:export": "ng extract-i18n --output-path src/locale",
    "release": "npx commit-and-tag-version -a",
    "update:angular": "ng update @angular/cli @angular/core",
    "build:changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 1",
    "build:releaselog": "node .github/scripts/extract-release.mjs",
    "build:prebuild": "npm run clean && npm run build:version",
    "build:version": "node ./build-pre.mjs",
    "build:stats": "ng build --named-chunks --configuration production --stats-json --output-hashing=none",
    "build:prod": "ng build --verbose --aot --configuration production --base-href \"/\"",
    "build:develop": "npm run build:prebuild && ng build --progress --base-href \"/\"",
    "build:deploy": "npm run build:prebuild && npm run build:prod",
    "analyze": "npm run build:stats && npx -y @angular-experts/hawkeye dist/stats.json"
  },
  "engines": {
    "node": ">=26"
  },
  "private": true,
  "commit-and-tag-version": {
    "scripts": {
      "postbump": "node ./build-pre.mjs && git add ./src/environments/version.ts"
    }
  },
  "overrides": {
    "minimatch": "10.2.5",
    "glob": "13.0.6",
    "@angular/build": {
      "typescript": "6.0.3"
    }
  },
  "dependencies": {
    "@angular/animations": "22.0.4",
    "@angular/cdk": "22.0.3",
    "@angular/common": "22.0.4",
    "@angular/compiler": "22.0.4",
    "@angular/core": "22.0.4",
    "@angular/forms": "22.0.4",
    "@angular/platform-browser": "22.0.4",
    "@angular/platform-browser-dynamic": "22.0.4",
    "@angular/router": "22.0.4",
    "@types/d3": "^7.4.3",
    "core-js": "3.49.0",
    "d3": "7.9.0",
    "mousetrap": "1.6.5",
    "ngx-image-cropper": "9.1.6",
    "rxjs": "7.8.2",
    "soundmanager2": "2.97.20170602",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.5",
    "@angular/cli": "22.0.5",
    "@angular/compiler-cli": "22.0.4",
    "@angular/language-service": "22.0.4",
    "@angular/localize": "22.0.4",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/mousetrap": "1.6.15",
    "@types/node": "26.1.0",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/eslint-plugin": "1.6.20",
    "angular-eslint": "22.0.0",
    "baseline-browser-mapping": "2.10.41",
    "conventional-changelog": "8.0.0",
    "conventional-changelog-angular": "9.2.0",
    "eslint": "10.6.0",
    "eslint-plugin-rxjs-x": "1.0.2",
    "eslint-plugin-unicorn": "70.0.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "postcss": "8.5.16",
    "rimraf": "6.1.3",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "fsevents@2.3.3": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true,
    "@parcel/watcher@2.5.6": true,
    "core-js@3.49.0": true
  }
}
